<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MessagesEncrypter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:MessagesEncrypter.Pages.Views"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            x:Uid="AppTitleBar"
            Background="Transparent"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="AppTitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Square44x44Logo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            CompactPaneLength="56"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            SelectionChanged="RootNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeNavItem" x:Uid="HomeNavItem" Tag="Home" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="EncryptNavItem" x:Uid="EncryptNavItem" Tag="Encrypt">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Mail" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="DecryptNavItem" x:Uid="DecryptNavItem" Tag="Decrypt">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Accept" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="RecipientKeysNavItem" x:Uid="RecipientKeysNavItem" Tag="RecipientKeys">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Permissions" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="PrivateKeysNavItem" x:Uid="PrivateKeysNavItem" Tag="PrivateKeys">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Contact" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem" x:Uid="SettingsNavItem" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer>
                    <Grid Padding="28">
                        <pages:HomeView x:Name="HomeView" />
                        <pages:EncryptView x:Name="EncryptView" Visibility="Collapsed" />
                        <pages:DecryptView x:Name="DecryptView" Visibility="Collapsed" />
                        <pages:RecipientKeysView x:Name="RecipientKeysView" Visibility="Collapsed" />
                        <pages:PrivateKeysView x:Name="PrivateKeysView" Visibility="Collapsed" />
                        <pages:SettingsView x:Name="SettingsView" Visibility="Collapsed" />
                    </Grid>
                </ScrollViewer>

                <ProgressRing
                    x:Name="OperationProgressRing"
                    Grid.Row="0"
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsActive="False"
                    Visibility="Collapsed" />

                <StackPanel Grid.Row="1">
                    <InfoBar
                        x:Name="StatusInfoBar"
                        Margin="28,16,28,28"
                        IsOpen="False"
                        IsClosable="True"
                        Visibility="Collapsed"
                        Closed="StatusInfoBar_Closed" />
                </StackPanel>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
