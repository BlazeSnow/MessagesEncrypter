<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MessagesEncrypter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:MessagesEncrypter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView
        x:Name="RootNavigation"
        x:Uid="RootNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="Left"
        SelectionChanged="RootNavigation_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="EncryptNavItem" x:Uid="EncryptNavItem" Tag="Encrypt" IsSelected="True">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Mail" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="DecryptNavItem" x:Uid="DecryptNavItem" Tag="Decrypt">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Accept" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="KeysNavItem" x:Uid="KeysNavItem" Tag="Keys">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Permissions" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="FilesNavItem" x:Uid="FilesNavItem" Tag="Files">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Document" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="SettingsNavItem" x:Uid="SettingsNavItem" Tag="Settings">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid Padding="28" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="PageTitleText"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <ScrollViewer Grid.Row="1">
                <Grid>
                    <StackPanel x:Name="EncryptPanel" Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">
                        <TextBlock x:Uid="RecipientKeyLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox
                            x:Name="RecipientKeyComboBox"
                            x:Uid="RecipientKeyComboBox"
                            DisplayMemberPath="DisplayName"
                            HorizontalAlignment="Stretch" />
                        <TextBlock x:Uid="EncryptPlainTextLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox
                            x:Name="PlainTextBox"
                            x:Uid="PlainTextBox"
                            AcceptsReturn="True"
                            Height="180"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="EncryptButton" Click="EncryptButton_Click" />
                            <Button x:Uid="CopyEncryptedMessageButton" Click="CopyEncryptedMessageButton_Click" />
                        </StackPanel>
                        <TextBlock x:Uid="EncryptedMessageLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox
                            x:Name="EncryptedMessageTextBox"
                            x:Uid="EncryptedMessageTextBox"
                            AcceptsReturn="True"
                            FontFamily="Consolas"
                            Height="180"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel x:Name="DecryptPanel" Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch" Visibility="Collapsed">
                        <TextBlock x:Uid="PrivateKeySelectionLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox
                            x:Name="PrivateKeyComboBox"
                            x:Uid="PrivateKeyComboBox"
                            DisplayMemberPath="DisplayName"
                            HorizontalAlignment="Stretch" />
                        <TextBlock x:Uid="CipherTextLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox
                            x:Name="CipherTextBox"
                            x:Uid="CipherTextBox"
                            AcceptsReturn="True"
                            FontFamily="Consolas"
                            Height="160"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="DecryptButton" Click="DecryptButton_Click" />
                            <Button x:Uid="PasteEncryptedMessageButton" Click="PasteEncryptedMessageButton_Click" />
                        </StackPanel>
                        <TextBlock x:Uid="DecryptedMessageLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox
                            x:Name="DecryptedMessageTextBox"
                            x:Uid="DecryptedMessageTextBox"
                            AcceptsReturn="True"
                            Height="160"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel x:Name="KeysPanel" Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch" Visibility="Collapsed">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="RecipientKeysListTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Uid="ImportRecipientKeyButton" Click="ImportRecipientKeyButton_Click" />
                                    <Button x:Uid="CopySelectedRecipientKeyButton" Click="CopySelectedRecipientKeyButton_Click" />
                                    <Button x:Uid="DeleteSelectedRecipientKeyButton" Click="DeleteSelectedRecipientKeyButton_Click" />
                                </StackPanel>
                                <ListView
                                    x:Name="RecipientKeysListView"
                                    DisplayMemberPath="DisplayName"
                                    MaxHeight="220" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock x:Uid="PrivateKeysListTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Uid="GenerateKeyButton" Click="GenerateKeyButton_Click" />
                                    <Button x:Uid="CopySelectedPrivatePublicKeyButton" Click="CopySelectedPrivatePublicKeyButton_Click" />
                                    <Button x:Uid="CopySelectedPrivateKeyButton" Click="CopySelectedPrivateKeyButton_Click" />
                                    <Button x:Uid="DeleteSelectedPrivateKeyButton" Click="DeleteSelectedPrivateKeyButton_Click" />
                                </StackPanel>
                                <ListView
                                    x:Name="PrivateKeysListView"
                                    DisplayMemberPath="DisplayName"
                                    MaxHeight="220" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="FilesPanel" Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch" Visibility="Collapsed">
                        <TextBlock x:Uid="FilesNotReadyTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Uid="FilesNotReadyDescription" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel x:Name="SettingsPanel" Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch" Visibility="Collapsed">
                        <controls:SettingsCard x:Uid="PrivateKeyPasswordSettingsCard">
                            <StackPanel Spacing="10">
                                <PasswordBox
                                    x:Name="PrivateKeyPasswordBox"
                                    x:Uid="PrivateKeyPasswordBox"
                                    MinWidth="320" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Uid="SavePrivateKeyPasswordButton" Click="SavePrivateKeyPasswordButton_Click" />
                                    <Button x:Uid="DeletePrivateKeyPasswordButton" Click="DeletePrivateKeyPasswordButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </controls:SettingsCard>
                        <TextBlock x:Uid="SecuritySummaryTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Uid="SecuritySummaryText" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <InfoBar
                x:Name="StatusInfoBar"
                Grid.Row="2"
                IsOpen="False"
                IsClosable="True" />
        </Grid>
    </NavigationView>
</Window>
