<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MessagesEncrypter.Views.RecipientKeysView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">
        <TextBlock x:Uid="RecipientKeysListTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Uid="ImportRecipientKeyButton" Click="ImportRecipientKeyButton_Click" />
            <Button x:Uid="OpenExportFolderButton" Click="OpenExportFolderButton_Click" />
        </StackPanel>
        <ItemsControl
            x:Name="RecipientKeysItemsControl"
            MinHeight="320">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="8" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:SettingsCard
                        Header="{Binding Alias}"
                        Description="{Binding FingerprintDisplay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                MinWidth="72"
                                VerticalAlignment="Center"
                                Text="{Binding KeyTypeDisplay}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Tag="{Binding}" Click="SelectRecipientKeyButton_Click">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE712;" />
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel MinWidth="180" Spacing="8">
                                            <Button x:Uid="CopySelectedRecipientKeyButton" HorizontalAlignment="Stretch" Tag="{Binding}" Click="CopySelectedRecipientKeyButton_Click" />
                                            <Button x:Uid="ExportSelectedRecipientKeyButton" HorizontalAlignment="Stretch" Tag="{Binding}" Click="ExportSelectedRecipientKeyButton_Click" />
                                            <Button x:Uid="DeleteSelectedRecipientKeyButton" HorizontalAlignment="Stretch" Tag="{Binding}" Click="DeleteSelectedRecipientKeyButton_Click" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </controls:SettingsCard>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
