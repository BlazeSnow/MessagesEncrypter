<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MessagesEncrypter.Views.DecryptView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">
        <TextBlock x:Uid="PrivateKeySelectionLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <ComboBox
            x:Name="PrivateKeyComboBox"
            x:Uid="PrivateKeyComboBox"
            DisplayMemberPath="DisplayName"
            HorizontalAlignment="Stretch" />
        <TextBlock x:Uid="CipherTextLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <TextBox
            x:Name="CipherTextBox"
            x:Uid="CipherTextBox"
            AcceptsReturn="True"
            FontFamily="Consolas"
            Height="160"
            TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Uid="DecryptButton" Click="DecryptButton_Click" />
            <Button x:Uid="PasteEncryptedMessageButton" Click="PasteEncryptedMessageButton_Click" />
        </StackPanel>
        <TextBlock x:Uid="DecryptedMessageLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <TextBox
            x:Name="DecryptedMessageTextBox"
            x:Uid="DecryptedMessageTextBox"
            AcceptsReturn="True"
            Height="160"
            TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
