<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MessagesEncrypter.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Grid MaxWidth="900" HorizontalAlignment="Stretch" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock x:Uid="HomeSendMessageTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <controls:SettingsCard x:Uid="HomeSendMessageStep1">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="1" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="HomeSendMessageStep2">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="2" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="HomeSendMessageStep3">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="3" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="HomeSendMessageStep4">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="4" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock x:Uid="HomeReceiveMessageTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <controls:SettingsCard x:Uid="HomeReceiveMessageStep1">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="1" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="HomeReceiveMessageStep2">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="2" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="HomeReceiveMessageStep3">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="3" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="HomeReceiveMessageStep4">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe UI" Glyph="4" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </StackPanel>
    </Grid>
</UserControl>
