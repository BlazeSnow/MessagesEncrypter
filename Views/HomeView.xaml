<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MessagesEncrypter.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid MaxWidth="900" HorizontalAlignment="Stretch" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock x:Uid="HomeSendMessageTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Uid="HomeSendMessageStep1" TextWrapping="Wrap" />
            <TextBlock x:Uid="HomeSendMessageStep2" TextWrapping="Wrap" />
            <TextBlock x:Uid="HomeSendMessageStep3" TextWrapping="Wrap" />
            <TextBlock x:Uid="HomeSendMessageStep4" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock x:Uid="HomeReceiveMessageTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Uid="HomeReceiveMessageStep1" TextWrapping="Wrap" />
            <TextBlock x:Uid="HomeReceiveMessageStep2" TextWrapping="Wrap" />
            <TextBlock x:Uid="HomeReceiveMessageStep3" TextWrapping="Wrap" />
            <TextBlock x:Uid="HomeReceiveMessageStep4" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
