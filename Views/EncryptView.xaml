<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MessagesEncrypter.Views.EncryptView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">
        <TextBlock x:Uid="RecipientKeyLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <ComboBox
            x:Name="RecipientKeyComboBox"
            x:Uid="RecipientKeyComboBox"
            DisplayMemberPath="DisplayName"
            HorizontalAlignment="Stretch" />
        <TextBlock x:Uid="EncryptPlainTextLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <TextBox
            x:Name="PlainTextBox"
            x:Uid="PlainTextBox"
            AcceptsReturn="True"
            Height="180"
            TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Uid="EncryptButton" Click="EncryptButton_Click" />
            <Button x:Uid="CopyEncryptedMessageButton" Click="CopyEncryptedMessageButton_Click" />
        </StackPanel>
        <TextBlock x:Uid="EncryptedMessageLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <TextBox
            x:Name="EncryptedMessageTextBox"
            x:Uid="EncryptedMessageTextBox"
            AcceptsReturn="True"
            FontFamily="Consolas"
            Height="180"
            TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
